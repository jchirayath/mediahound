# Sign + notarize the MediaHound desktop app with Fastlane.
#
# NOTE: MediaHound has no iOS target. The downloadable app is a **macOS** .app (built by
# PyInstaller — see packaging/). This signs it for distribution outside the App Store with a
# **Developer ID Application** certificate, reusing your existing Apple Developer account.
#
# Usage (after a build produces dist/MediaHound.app):
#   bundle exec fastlane mac sign
#   bundle exec fastlane mac sign app:dist/MediaHound.app
#
# Required env (see ../SIGNING.md):
#   MAC_SIGN_IDENTITY   "Developer ID Application: Your Name (TEAMID)"
# Notarization auth — EITHER an App Store Connect API key (recommended):
#   ASC_KEY_ID, ASC_ISSUER_ID, ASC_KEY_FILE (path to AuthKey_*.p8)
# OR an Apple ID + app-specific password:
#   APPLE_ID, APPLE_TEAM_ID, APPLE_APP_PASSWORD
# Optional:
#   MATCH_GIT_URL       if set, the Developer ID cert is fetched with `match` (your existing repo)

require "shellwords"

REPO_ROOT = File.expand_path("..", __dir__)

default_platform(:mac)

platform :mac do
  desc "Codesign + notarize the built MediaHound.app (Developer ID, outside the App Store)"
  lane :sign do |options|
    app = File.join(REPO_ROOT, options[:app] || "dist/MediaHound.app")
    UI.user_error!("App not found: #{app}\nBuild it first:  bash packaging/build-desktop.sh") unless File.exist?(app)
    identity = ENV["MAC_SIGN_IDENTITY"] || UI.user_error!("Set MAC_SIGN_IDENTITY")

    # Reuse your existing Fastlane match certs if you keep a match repo; otherwise the
    # Developer ID cert just needs to be in the login keychain.
    match(type: "developer_id", platform: "macos", readonly: true) if ENV["MATCH_GIT_URL"]

    UI.message("Codesigning #{app} …")
    sh("codesign --deep --force --options runtime --timestamp " \
       "--sign #{identity.shellescape} #{app.shellescape}")

    UI.message("Notarizing (this can take a few minutes) …")
    if !ENV["ASC_KEY_ID"].to_s.empty? && !ENV["ASC_ISSUER_ID"].to_s.empty?
      # App Store Connect API key (recommended — no app-specific password needed)
      api_key = app_store_connect_api_key(
        key_id: ENV["ASC_KEY_ID"],
        issuer_id: ENV["ASC_ISSUER_ID"],
        key_filepath: ENV["ASC_KEY_FILE"] || File.join(__dir__, "AuthKey.p8"),
      )
      notarize(package: app, bundle_id: "com.chirayath.mediahound", api_key: api_key, print_log: true)
    else
      # fallback: Apple ID + app-specific password
      notarize(package: app, bundle_id: "com.chirayath.mediahound",
               username: ENV["APPLE_ID"], asc_provider: ENV["APPLE_TEAM_ID"], print_log: true)
    end

    sh("xcrun stapler staple #{app.shellescape}")
    UI.success("✅ Signed + notarized: #{app}")
  end
end
